# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Direct PostgreSQL — from Supabase Settings → Database)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL_POOLED=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Channex (Channel Manager)
CHANNEX_API_URL=https://app.channex.io/api/v1
CHANNEX_API_KEY=your-channex-api-key

# AirROI (Market Data)
AIRROI_BASE_URL=https://api.airroi.com
AIRROI_API_KEY=your-airroi-api-key

# Anthropic (Guest Messaging AI)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Ticketmaster (Event Data — free)
TICKETMASTER_API_KEY=your-ticketmaster-api-key

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# App URL (canonical — used for webhook callbacks, SMS links, internal fetches)
NEXT_PUBLIC_APP_URL=https://app.koasthq.com

# BDC calendar-push gate. Default off until Track B Stage 1 ships the safe-
# restrictions helper (F1-F6 in docs/postmortems/INCIDENT_POSTMORTEM_BDC_CLOBBER.md).
# Set to "true" ONLY when you know what you're doing.
KOAST_ALLOW_BDC_CALENDAR_PUSH=false
