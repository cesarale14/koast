                }`}>{sc.confidence} confidence</span>
              </div>
            </div>
            <p className="text-sm text-neutral-600 mb-1">{sc.recommendation}</p>
            <p className="text-xs text-neutral-400">{sc.details}</p>
          </div>
        ))}
      </div>
    </div>
  );
}
