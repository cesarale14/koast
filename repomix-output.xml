import type { LucideIcon } from "lucide-react";

interface NavItem { name: string; href: string; icon: LucideIcon; badge?: boolean; external?: boolean; }
interface NavGroup { label?: string; items: NavItem[]; }

const navGroups: NavGroup[] = [
