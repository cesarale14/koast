  /* Sidebar */
  --sidebar-bg: #0f1117;
  --sidebar-text: #a1a1aa;
  --sidebar-text-active: #ffffff;
  --sidebar-hover: rgba(255, 255, 255, 0.06);
  --sidebar-active-bg: rgba(16, 185, 129, 0.12);
  --sidebar-active-text: #34d399;
  --sidebar-border: rgba(255, 255, 255, 0.08);

  /* Semantic */
  --success: #10b981;
  --success-light: #ecfdf5;
  --warning: #f59e0b;
  --warning-light: #fffbeb;
  --danger: #ef4444;
  --danger-light: #fef2f2;
  --info: #3b82f6;
  --info-light: #eff6ff;

  /* Platform colors */
  --airbnb: #FF5A5F;
  --vrbo: #3B5998;
  --booking-com: #003580;
  --direct: var(--brand-500);

  /* Shadows */
  --shadow-sm: 0 1px 2px rgba(12, 10, 9, 0.04);
  --shadow-md: 0 2px 8px rgba(12, 10, 9, 0.06), 0 1px 2px rgba(12, 10, 9, 0.04);
  --shadow-lg: 0 4px 16px rgba(12, 10, 9, 0.08), 0 2px 4px rgba(12, 10, 9, 0.04);
  --shadow-xl: 0 8px 32px rgba(12, 10, 9, 0.10), 0 4px 8px rgba(12, 10, 9, 0.04);

  /* Borders */
  --border: #e7e5e4;
  --border-hover: #d6d3d1;
  --border-focus: var(--brand-500);

  /* Radius */
  --radius-sm: 6px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
