  --brand-700: #047857;
  --brand-800: #065f46;
  --brand-900: #064e3b;
  --brand-950: #022c22;

  /* Neutrals — warm grays */
  --neutral-0: #ffffff;
  --neutral-25: #fafaf9;
  --neutral-50: #f5f5f4;
  --neutral-100: #e7e5e4;
  --neutral-200: #d6d3d1;
  --neutral-300: #a8a29e;
  --neutral-400: #78716c;
