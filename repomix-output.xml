  --text-lg: 1.125rem;
  --text-xl: 1.25rem;
  --text-2xl: 1.5rem;
  --text-3xl: 1.875rem;
  --text-4xl: 2.25rem;

  /* Transitions */
  --transition-fast: 120ms ease;
  --transition-base: 200ms ease;
  --transition-slow: 300ms ease;
}

html, body {
  overflow-x: hidden;
  max-width: 100vw;
}

body {
  font-family: 'Nunito Variable', system-ui, sans-serif;
  color: var(--neutral-700);
  background: var(--neutral-25);
  font-size: var(--text-base);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Revenue/stat numbers get monospace treatment */
.font-mono, [data-stat], .stat-value {
  font-family: 'Nunito Variable', system-ui, sans-serif;
  font-feature-settings: 'tnum';
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.01em;
  font-weight: 700;
}

/* Subtle page transitions */
.page-enter {
  animation: fadeIn var(--transition-slow) ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}

@layer utilities {
  .text-balance {
    text-wrap: balance;
  }
}

@keyframes slide-in-right {
  from { transform: translateX(100%); }
  to { transform: translateX(0); }
}

.animate-slide-in {
  animation: slide-in-right 0.25s ease-out;
}

@keyframes slide-in-left {
  from { transform: translateX(-100%); }
  to { transform: translateX(0); }
}

.animate-slide-in-left {
  animation: slide-in-left 0.2s ease-out;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.skeleton {
  background: linear-gradient(90deg, var(--neutral-100) 25%, var(--neutral-50) 50%, var(--neutral-100) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-md);
}

/* ---------- 3D Depth System ---------- */

/* Stat cards — shadow-only, no border */
.stat-card {
  box-shadow:
    0 1px 3px rgba(12,10,9,0.06),
    0 4px 12px rgba(12,10,9,0.04);
  transition: all var(--transition-base);
}
.stat-card:hover {
  transform: translateY(-2px);
  box-shadow:
    0 2px 4px rgba(12,10,9,0.04),
    0 8px 16px rgba(12,10,9,0.06),
    0 16px 32px rgba(12,10,9,0.04);
}
.stat-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.8), transparent);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  pointer-events: none;
}

/* Key highlight cards — slightly more depth to draw the eye */
.card-elevated {
  box-shadow:
    0 2px 4px rgba(12,10,9,0.04),
    0 8px 24px rgba(12,10,9,0.06);
  transition: all var(--transition-base);
}

/* Primary buttons — raised with press effect */
.btn-primary-3d {
  box-shadow:
    0 1px 2px rgba(5,150,105,0.3),
