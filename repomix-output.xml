      property_id: propertyId,
      template_type: t.templateType,
      subject: t.subject,
      body: t.body,
      is_active: true,
      trigger_type: t.triggerType,
      trigger_days_offset: t.triggerDaysOffset,
      trigger_time: t.triggerTime,
